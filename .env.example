VITE_CONVEX_URL=https://your-deployment.convex.cloud
VITE_CONVEX_STATE_KEY=libabite-main
VITE_CUSTOMER_SITE_URL=https://libabite-order.thatcanadian.dev
VITE_STAFF_APP_URL=https://libabite-work.thatcanadian.dev
# Comma-separated browser-visible checkout choices. Keep this aligned with the
# provider keys configured in Convex; production currently defaults to Stripe.
VITE_ONLINE_PAYMENT_PROVIDERS=stripe

# Set to true when you want to force local browser storage only.
VITE_CONVEX_DISABLED=false

# Local receipt-printer agent. These are read by npm run printer:agent.
CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_STATE_KEY=libabite-main
RECEIPT_PRINTER_HOST=192.168.1.50
RECEIPT_PRINTER_PORT=9100
RECEIPT_DRY_RUN=false

# Everything below is server-only. Set it with `npx convex env set`; never use
# VITE_ prefixes for payment, webhook, Mailchimp, or marketplace secrets.

# Public customer origin used by Convex to generate payment return URLs.
CUSTOMER_SITE_URL=https://libabite-order.thatcanadian.dev

# Stripe Checkout and signed POST /payments/stripe/webhook verification.
STRIPE_SECRET_KEY=sk_test_or_live_key
STRIPE_WEBHOOK_SECRET=whsec_endpoint_signing_secret

# Optional. Leave blank to keep Mollie checkout disabled. Mollie posts a payment
# id to /payments/mollie/webhook, which Convex verifies with this server key.
MOLLIE_API_KEY=

# One-to-one order/reservation email through Mailchimp Transactional.
# Provider currently defaults to mailchimp_transactional when omitted.
TRANSACTIONAL_EMAIL_PROVIDER=mailchimp_transactional
MAILCHIMP_TRANSACTIONAL_API_KEY=
MAILCHIMP_TRANSACTIONAL_FROM_EMAIL=orders@libabite-order.thatcanadian.dev
# Optional; defaults to Libabite.
MAILCHIMP_TRANSACTIONAL_FROM_NAME=Libabite
MAILCHIMP_TRANSACTIONAL_REPLY_TO=

# Mailchimp E-commerce transactional/non-subscribed contact sync. The store must
# already exist and be linked to the configured audience. The public checkbox
# starts unticked; only an explicit opt-in advances a member to pending/double opt-in.
MAILCHIMP_MARKETING_API_KEY=
MAILCHIMP_MARKETING_AUDIENCE_ID=
MAILCHIMP_MARKETING_STORE_ID=
# Optional; normally derived from an API-key suffix such as -us21.
MAILCHIMP_MARKETING_SERVER_PREFIX=

# External delivery API approvals/secrets. Keep these server-side.
UBER_EATS_CLIENT_ID=
UBER_EATS_CLIENT_SECRET=
UBER_EATS_STORE_ID=
JET_CONNECT_CLIENT_ID=
JET_CONNECT_CLIENT_SECRET=
JET_CONNECT_LOCATION_ID=
